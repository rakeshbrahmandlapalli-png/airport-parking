// This tells Prisma to create the "Client" engine
generator client {
  provider = "prisma-client-js"
}

// This tells Prisma where your Neon database is
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// These are your database tables (The "Parking Lot" and "Bookings")
model ParkingLot {
  id          String    @id @default(cuid())
  name        String
  pricePerDay Float
  capacity    Int
  bookings    Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String   // Ensure this is here
  customerPhone String   // Ensure this is here
  flightNumber  String   // Ensure this is here
  licensePlate  String
  parkingType   String
  totalPrice    Float
  status        String   @default("pending")
  createdAt     DateTime @default(now())
}