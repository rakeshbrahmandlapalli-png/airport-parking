generator client {
  provider = "prisma-client-node"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String
  flightNumber  String
  licensePlate  String
  parkingType   String
  totalPrice    Float
  status        String   @default("pending")
  createdAt     DateTime @default(now())
}