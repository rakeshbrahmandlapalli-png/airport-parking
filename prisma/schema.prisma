// 1. GENERATOR - This creates the code that lets your app talk to the DB
generator client {
  provider = "prisma-client-js"
}

// 2. DATASOURCE - This connects to your Supabase/PostgreSQL database
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. BOOKING MODEL - This saves all your customer and flight data
model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String
  flightNumber  String
  licensePlate  String
  parkingType   String
  totalPrice    Float
  status        String   @default("pending")
  
  // 🔥 NEW FIELDS ADDED HERE:
  airport       String?  @default("Luton Airport (LTN)") 
  terminal      String?  @default("Main Terminal")       
  
  createdAt     DateTime @default(now())
}