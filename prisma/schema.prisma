generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model bookings {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  full_name         String
  
  // 🟢 FIXED: Made optional with a default. This permanently prevents the "not-null constraint" crash.
  service_type      String?    @default("Premium Meet & Greet")
  
  dropoff_date      DateTime   @db.Date
  pickup_date       DateTime   @db.Date
  total_price       Decimal    @db.Decimal
  booking_ref       String?
  flight_number     String?
  phone_number      String?
  car_make          String?
  car_color         String?
  additional_notes  String?
  license_plate     String?
  email             String?
  airport           String?    @default("Luton Airport (LTN)")
  terminal          String?    @default("Main Terminal")
  
  dropoff_time      String?    
  pickup_time       String?    
  
  sms_sent          Boolean?   @default(false)
  status            String?    @default("pending") 
  
  company_id        String?    @db.Uuid
  stripe_session_id String?    @unique
  companies         companies? @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model companies {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  category             String
  luton_price          Decimal    @db.Decimal
  heathrow_price       Decimal    @db.Decimal
  
  // 🟢 NEW: Split Dynamic Pricing Tiers per Airport
  ltn_tier1_extra_rate Decimal?   @default(1.99) @db.Decimal // LTN Days 2 to 6
  ltn_tier2_extra_rate Decimal?   @default(2.99) @db.Decimal // LTN Days 7+
  lhr_tier1_extra_rate Decimal?   @default(1.99) @db.Decimal // LHR Days 2 to 6
  lhr_tier2_extra_rate Decimal?   @default(2.99) @db.Decimal // LHR Days 7+

  is_sold_out          Boolean?   @default(false)
  updated_at           DateTime?  @default(now()) @db.Timestamptz(6)
  is_recommended       Boolean?   @default(false)
  operates_at_luton    Boolean?   @default(true)
  operates_at_heathrow Boolean?   @default(true)
  overview             String?
  on_arrival           String?
  on_return            String?
  address              String?
  postcode             String?
  map_url              String?
  phone_number         String?    @default("07700 900 123")
  map_location         String?    @default("Details provided at terminal")
  on_arrival_lhr       String?
  on_arrival_ltn       String?
  on_return_lhr        String?
  on_return_ltn        String?
  is_active            Boolean?   @default(true)
  is_featured          Boolean?   @default(false)
  ltn_sold_out         Boolean?   @default(false)
  lhr_sold_out         Boolean?   @default(false)
  ltn_featured         Boolean?   @default(false)
  lhr_featured         Boolean?   @default(false)
  reviews              Json?      @default("[]")
  commission_rate      Int?       @default(15)
  logo_url             String?
  ltn_reviews          Json?      @default("[]")
  lhr_reviews          Json?      @default("[]")
  bookings             bookings[]
}